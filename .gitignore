# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Runtime-uploaded images (live on the server's disk, not in git)
/public/uploads/

# --- QA / tooling artifacts (not part of the website) ---
# Playwright + Puppeteer QA tests and screenshot scripts
/tests/
/scripts/
playwright.config.ts
/playwright-report/
/test-results/
/.playwright/

# Captured screenshots / audit output
/shots/
/shots-*/

# Design + working docs
DESIGN-BLUEPRINT.md

# Local logs
*.log
dev.log
prod.log
